# Auto-detect text files and normalize line endings to LF on checkin
* text=auto eol=lf

# Explicitly declare text files
*.cs        text eol=lf diff=csharp
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.sln       text eol=lf
*.editorconfig text eol=lf

*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf

*.sh        text eol=lf
*.bash      text eol=lf
Makefile    text eol=lf

*.md        text eol=lf diff=markdown
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.proto     text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.dll       binary
*.exe       binary
*.pdf       binary

# Generated code — exclude from GitHub diff and language stats
**/Generated/** linguist-generated
**/generated/** linguist-generated
