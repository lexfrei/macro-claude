<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <RootNamespace>Loupedeck.MacroClaudePlugin.Tests</RootNamespace>


    <!-- Test code suppressions: xunit requires underscores in test names
         (CA1707), tests don't care about ConfigureAwait (CA2007), var
         for local locals is fine in test scaffolding (IDE0008), and
         unused discard assignments are common (IDE0058). -->
    <NoWarn>$(NoWarn);CA1707;CA2007;IDE0008;IDE0058</NoWarn>
  </PropertyGroup>

  <!--
    Tests consume the pure logic classes directly as linked sources rather
    than via a ProjectReference to MacroClaudePlugin, which would drag in
    the Loupedeck PluginApi native reference and custom build targets.
    Each source file listed here has zero Loupedeck dependencies —
    StateResolver, SessionSnapshot (+ SessionState), and SlotAssigner are
    plain C# with only BCL types.
  -->
  <ItemGroup>
    <Compile Include="..\MacroClaudePlugin\src\Status\StateResolver.cs">
      <Link>Linked\StateResolver.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Status\StateResolverConfig.cs">
      <Link>Linked\StateResolverConfig.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Status\SessionSnapshot.cs">
      <Link>Linked\SessionSnapshot.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Status\SlotAssigner.cs">
      <Link>Linked\SlotAssigner.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Status\GitRepoResolver.cs">
      <Link>Linked\GitRepoResolver.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Status\SlotBus.cs">
      <Link>Linked\SlotBus.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Status\ReconcileDecision.cs">
      <Link>Linked\ReconcileDecision.cs</Link>
    </Compile>
    <Compile Include="..\MacroClaudePlugin\src\Focus\VSCodeUrlEncoder.cs">
      <Link>Linked\VSCodeUrlEncoder.cs</Link>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3" Version="3.2.2" />
  </ItemGroup>

</Project>
